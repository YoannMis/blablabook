POSTGRES_USER=database_username
POSTGRES_PASSWORD=database_password
POSTGRES_DB=database_name

POSTGRES_PORT=enter_a_port_for_postgres

PG_VERSION=18_or_above

NODE_ENV=production

JWT_SECRET=random_token_characters_min_32
JWT_EXPIRES_IN=time_expressed_in_seconds_or_a_string_describing_a_time_span_vercel/ms
REFRESH_TOKEN_EXPIRES_IN=time_expressed_in_seconds_or_a_string_describing_a_time_span_vercel/ms

BACKEND_LOCAL_PORT=enter_a_port_for_express_server

DATABASE_URL="postgres://blablabook:blablabook@blablabook-db:5434/blablabook"

CORS_ORIGIN=frontend_url

ADMINER_PORT=enter_a_port_for_adminer


FRONT_LOCAL_PORT=enter_a_port_for_nginx_server
VITE_API_URL=your_backend_api_base_url_here

GOOGLE_BOOKS_API_BASE_URL=https://www.googleapis.com/books/v1/volumes
GOOGLE_BOOKS_API_KEY=your_google_books_api_key